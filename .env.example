# ============================================================
# Copie este arquivo para .env.local e preencha com os valores
# do seu projeto Firebase (Console > Configurações do projeto >
# Seus apps > App da Web > Configuração do SDK).
# ============================================================

# Firebase (públicos — identificam o projeto, não são segredos)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ============================================================
# SEGREDOS DO BACKEND — nunca use prefixo NEXT_PUBLIC_ aqui.
# Em produção ficam nos secrets do Firebase Functions / Vercel.
# ============================================================

# OpenAI (transcrição Whisper + análise GPT-4o)
OPENAI_API_KEY=

# Modo simulado da IA (sem custo): AI_MOCK=true faz o pipeline devolver uma
# análise de exemplo sem chamar a OpenAI. Deixe em branco/false em produção.
AI_MOCK=

# Firebase Admin (backend). Duas formas — escolha UMA:
#
# A) Mais simples (dev): baixe a chave privada em
#    Console > Configurações do projeto > Contas de serviço > Gerar nova
#    chave privada, e salve o arquivo como "service-account.json" na raiz
#    do projeto (simplifica-sales-academy/). Ele já está no .gitignore.
#
# B) Variáveis de ambiente (recomendado em produção):
# FIREBASE_ADMIN_PROJECT_ID=
# FIREBASE_ADMIN_CLIENT_EMAIL=
# FIREBASE_ADMIN_PRIVATE_KEY=

# Retencao das gravacoes em dias (LGPD). Padrao: 60.
NEXT_PUBLIC_RETENTION_DAYS=60

# Segredo para o agendador chamar /api/admin/retention (header x-cron-secret).
CRON_SECRET=
