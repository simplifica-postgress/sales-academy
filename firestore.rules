rules_version = '2';

// PRINCÍPIO 1: o cliente nunca escreve nada que afete avaliação, progresso ou
// permissão. Tudo isso é gravado só pelo backend (Admin SDK, que ignora estas
// regras). O cliente só edita os campos do próprio perfil.
//
// PRINCÍPIO 2 (multi-empresa): o gestor só enxerga a PRÓPRIA empresa. Como as
// regras do Firestore não fazem join, cada documento de vendedor (uploads,
// analyses, progress) carrega uma cópia do companyId do dono. A comparação é
// sempre contra o companyId do próprio solicitante, lido do doc dele.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMaster() {
      return isSignedIn() && me().role == 'master';
    }

    // Gestor da empresa `cid`. O `cid != null` é essencial: sem ele, um gestor
    // sem empresa passaria a enxergar todo mundo que também está sem empresa.
    function isManagerOf(cid) {
      return isSignedIn()
        && me().role == 'manager'
        && cid != null
        && me().companyId == cid;
    }

    // Campos que o vendedor pode editar no próprio perfil.
    // Fora desta lista (role, companyId, profileCompleted, trainingStartDate,
    // currentDay, progressPercent, averageScore, currentLevel) só o backend
    // grava — inclusive companyId, para ninguém se mudar de empresa sozinho.
    function editableProfileKeys() {
      return [
        'name', 'company', 'salesRole', 'experience',
        'attendanceTypes', 'mainDifficulty', 'goal'
      ];
    }

    // Empresas: leitura para master e para o gestor da própria empresa.
    // Escrita só pelo backend (endpoint protegido por papel master).
    match /companies/{companyId} {
      allow read: if isMaster() || isManagerOf(companyId);
      allow write: if false;
    }

    // Usuários: cada um lê o próprio; master lê todos; gestor lê só quem
    // está na empresa dele.
    match /users/{userId} {
      allow read: if isSelf(userId)
        || isMaster()
        || isManagerOf(resource.data.companyId);

      // Criação no primeiro login: sempre vendedor, sem empresa e sem progresso.
      allow create: if isSelf(userId)
        && request.resource.data.role == 'seller'
        && request.resource.data.companyId == null
        && request.resource.data.profileCompleted == false
        && request.resource.data.progressPercent == 0
        && request.resource.data.averageScore == 0
        && request.resource.data.currentLevel == 1
        && request.resource.data.currentDay == 0
        && request.resource.data.trainingStartDate == null;

      // Edição pelo cliente: apenas campos de perfil.
      // Impede forjar progresso/nível e escalada de privilégio (role/companyId).
      allow update: if isSelf(userId)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(editableProfileKeys());

      allow delete: if false;
    }

    // Progresso: dono, master ou gestor da empresa do dono. Escrita só backend.
    match /progress/{userId} {
      allow read: if isSelf(userId)
        || isMaster()
        || isManagerOf(resource.data.companyId);
      allow write: if false;
    }

    // Envios: dono, master ou gestor da empresa do dono. Criados pelo backend
    // após o arquivo chegar ao Storage.
    match /uploads/{uploadId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid
            || isMaster()
            || isManagerOf(resource.data.companyId));
      allow write: if false;
    }

    // Análises: geradas apenas pelo backend; mesma visibilidade dos envios.
    match /analyses/{analysisId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid
            || isMaster()
            || isManagerOf(resource.data.companyId));
      allow write: if false;
    }

    // Princípios e Casos: material de treinamento que alimenta a IA.
    // Qualquer pessoa logada LÊ (a análise cita "Princípio N", e sem poder
    // consultar a lista a citação seria inútil para o vendedor). Só o master
    // escreve.
    match /knowledge/{docId} {
      allow read: if isSignedIn();
      allow write: if isMaster();
    }

    // Vídeos e aulas: material de treinamento da Simplifica, igual para todas
    // as empresas. Qualquer pessoa logada assiste; só o master cadastra.
    match /videos/{docId} {
      allow read: if isSignedIn();
      allow write: if false; // gravado só pelo backend (endpoint de master)
    }

    // Nega qualquer coleção não declarada acima.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
